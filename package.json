{
  "name": "nexus-agents",
  "version": "1.1.0",
  "description": "Agentic skills, prompts, agents, and instructions for AI platforms.",
  "bin": {
    "nxa": "bin/nxa.js"
  },
  "scripts": {
    "test": "node --test",
    "validate": "node scripts/validation/validate-skills.js",
    "scan": "python scripts/catalog/scan-skills.py skills --output skill-catalog-scan.json",
    "catalog": "python scripts/catalog/rebuild-catalog.py",
    "build:plugins": "node scripts/build/build-plugins.js",
    "build:site": "node scripts/build/build-site.js",
    "build": "npm run validate && npm run scan && npm run catalog && npm run build:plugins && npm run build:site"
  },
  "files": [
    "bin/",
    "scripts/",
    "src/",
    "README.md",
    "LICENSE.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scanady/nexus-skills.git"
  },
  "keywords": [
    "skills",
    "prompts",
    "agents",
    "instructions",
    "ai"
  ],
  "author": "iFoundry",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/scanady/nexus-skills/issues"
  },
  "homepage": "https://github.com/scanady/nexus-skills#readme"
}
